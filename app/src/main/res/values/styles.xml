<resources>
    <style name="button">
        <item name="android:backgroundTint">@color/ocean_primary</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:layout_width">150dp</item>
        <item name="android:layout_height">50dp</item>
    </style>
    <style name="buttonWin">
        <item name="android:backgroundTint">@color/ocean_primary</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:layout_width">200dp</item>
        <item name="android:layout_height">75dp</item>
    </style>
    <style name="text">
        <item name="android:layout_width">100dp</item>
        <item name="android:layout_height">20dp</item>
        <item name="android:textColor">@color/ocean_accent</item>
    </style>
    <style name="colorDark">
        <item name="android:textColor">@color/ocean_progress</item>
    </style>
</resources>